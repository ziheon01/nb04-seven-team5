// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {

  Id                Int           @id
  groupName         String        @unique
  description       String?
  groupPhoto        GroupPhoto?
  groupBadge        GroupBadge?
  goalRep           Int           @default(0) //RecordмЧРмДЬ лВШмШ® лН∞мЭінД∞л•Љ participantмЧРмДЬ м†Хл¶ђнХімДЬ л∞ЫмХДмШ§лПДл°Э мґФнЫД нЩХмЭЄ
  discordWebHookURl String        @unique
  discordInviteUrl  String        @unique
  tag               Tag[]
  ownerNickname     String        @unique
  ownerPassword     String
  Badge             groupBadge    @relation(fields: [groupBadgeBadgeId], references: [Id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  participant       Participant[]
}

model Participant {
  id              Int              @id
  group           Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId         Int
  nickname        String           @unique
  password        String
  recordCount     Int              @default(0) //RecordId лН∞мЭінД∞л•Љ participantIdлЮС мЭЉмєШмЛЬнВ® к∞ѓмИШл•Љ нММмХЕнХімДЬ кЄ∞мЮЕнХШлПДл°Э
  recordTime      Int              @default(0) //RecordмЧРмДЬ timeмЭШ міЭнХ©мЭД к≥ДмВ∞нХімДЬ м†АмЮ•нХ† мИШ мЮИлПДл°Э нЩХмЭЄ
  likeId          Like?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  exerciseRecords ExerciseRecord[] 
  @@unique(name: "participantInfo", [nickname, password])

}

model Like {
  Id                       Int         @id
  participantId            Participant @relation(fields: [participantParticipantId], references: [Id])
  Group                    Group?      @relation(fields: [groupGroupId], references: [Id])
  groupGroupId             Int?
  participantParticipantId Int         @unique
}

model ExerciseRecord {
  id                  Int                @id
  groupId             Int
  participant         Participant        @relation(fields: [participantId], references: [id], onDelete: Cascade)
  exerciseType        ExerciseType       @default(running)
  description         String
  time                Int                @default(0) //нФДл°†нКЄ мЧФлУЬмЭШ мК§нЖ±мЫМмєШ мЛЬмК§нЕЬмЭД нЩХмЭЄ
  distance            Int                @default(0)
  participantId       Int
  participantPhoto    ParticipantPhoto[]
}

model ParticipantPhoto {
  id               Int            @id
  exerciseRecordId Int
  exerciseRecord   ExerciseRecord @relation(fields: [exerciseRecordId], references: [id], onDelete: Cascade)
  photoUrl         String         @unique
}

model groupPhoto {
  Id           Int    @id
  groupId      Int
  photoUrl     String
  groups       Group  @relation(fields: [groupGroupId], references: [Id])
  groupGroupId Int    @unique
}

model groupBadge {
  Id                     Int     @id
  groupId                Group?
  participantsOver10     Boolean @default(false)
  recordsOver100         Boolean @default(false)
  recommandationsOver100 Boolean @default(false)
}

model Tag {

  Id           String   @id
  groupId      Group    @relation(fields: [groupGroupId], references: [Id])
  tagName      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt()
  groupGroupId Int
}

enum ExerciseType {
  running
  cycling
  swimming
}
