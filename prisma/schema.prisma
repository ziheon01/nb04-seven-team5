// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  Id                Int           @id
  groupName         String        @unique
  photoUrls         groupPhoto?
  goalRep           Int           @default(0)
  discordWebHookURl String        @unique
  likeCounts        Like[]
  tags              Tag[]
  ownerNickname     String        @unique
  ownerPassword     String
  Badge             groupBadge    @relation(fields: [groupBadgeBadgeId], references: [Id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  Participants      Participant[]
  groupPhotoPhotoId Int
  groupBadgeBadgeId Int           @unique
}

model Participant {
  Id                Int                @id
  groupId           Group              @relation(fields: [groupGroupId], references: [Id])
  groupGroupId      Int
  nickname          String             @unique
  password          String
  recordCount       Int                @default(0)
  likeId            Like?
  exerciseRecords   ExerciseRecord[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  ParticipantPhotos ParticipantPhoto[]
}

model Like {
  Id                       Int         @id
  participantId            Participant @relation(fields: [participantParticipantId], references: [Id])
  Group                    Group?      @relation(fields: [groupGroupId], references: [Id])
  groupGroupId             Int?
  participantParticipantId Int         @unique
}

model ExerciseRecord {
  Id                       Int              @id
  recordId                 Int
  participantId            Participant      @relation(fields: [participantParticipantId], references: [Id])
  groupId                  Int
  exerciseType             exerciseType     @default(running)
  distance                 Int              @default(0)
  photos                   ParticipantPhoto @relation(fields: [participantPhotoPhotoId], references: [Id])
  participantParticipantId Int
  participantPhotoPhotoId  Int              @unique
}

model ParticipantPhoto {
  Id                       Int             @id
  recordId                 ExerciseRecord?
  participantId            Participant     @relation(fields: [participantParticipantId], references: [Id])
  photoUrl                 String          @unique
  participantParticipantId Int
}

model groupPhoto {
  Id           Int    @id
  groupId      Int
  photoUrl     String
  groups       Group  @relation(fields: [groupGroupId], references: [Id])
  groupGroupId Int    @unique
}

model groupBadge {
  Id                     Int     @id
  groupId                Group?
  participantsOver10     Boolean @default(false)
  recordsOver100         Boolean @default(false)
  RecommandationsOver100 Boolean @default(false)
}

model Tag {
  Id           String   @id
  groupId      Group    @relation(fields: [groupGroupId], references: [Id])
  tagName      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt()
  groupGroupId Int
}

enum exerciseType {
  running
  cycling
  swimming
}
