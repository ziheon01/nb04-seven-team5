// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  id                Int           @id
  groupName         String        @unique
  description       String?
  groupPhoto        GroupPhoto?
  groupBadge        GroupBadge?
  goalRep           Int           @default(0) //Record에서 나온 데이터를 participant에서 정리해서 받아오도록 추후 확인
  discordWebHookURl String        @unique
  discordInviteUrl  String        @unique
  tag               Tag[]
  ownerNickname     String        @unique
  ownerPassword     String
  Badge             groupBadge    @relation(fields: [groupBadgeBadgeId], references: [Id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  participant       Participant[]
}

model Participant {
  Id                Int                @id
  groupId           Group              @relation(fields: [groupGroupId], references: [Id])
  groupGroupId      Int
  nickname          String             @unique
  password          String
  recordCount       Int                @default(0)
  likeId            Like?
  exerciseRecords   ExerciseRecord[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  ParticipantPhotos ParticipantPhoto[]
}

model Like {
  Id                       Int         @id
  participantId            Participant @relation(fields: [participantParticipantId], references: [Id])
  Group                    Group?      @relation(fields: [groupGroupId], references: [Id])
  groupGroupId             Int?
  participantParticipantId Int         @unique
}

model ExerciseRecord {
  Id                       Int              @id
  recordId                 Int
  participantId            Participant      @relation(fields: [participantParticipantId], references: [Id])
  groupId                  Int
  exerciseType             exerciseType     @default(running)
  distance                 Int              @default(0)
  photos                   ParticipantPhoto @relation(fields: [participantPhotoPhotoId], references: [Id])
  participantParticipantId Int
  participantPhotoPhotoId  Int              @unique
}

model ParticipantPhoto {
  id               Int            @id
  exerciseRecordId Int
  exerciseRecord   ExerciseRecord @relation(fields: [exerciseRecordId], references: [id], onDelete: Cascade)
  photoUrl         String         @unique
}

model groupPhoto {
  photoId      Int    @id
  groupId      Int
  photoUrl     String
  groups       Group  @relation(fields: [groupGroupId], references: [groupId])
  groupGroupId Int    @unique
}

model groupBadge {
  badgeId                Int      @id
  groupId                Group? 
  participantsOver10     Boolean @default(false)
  recordsOver100         Boolean @default(false)
  recommandationsOver100 Boolean @default(false)
}

model Tag {
  tagId        String   @id
  groupId      Group    @relation(fields: [groupGroupId], references: [groupId])
  tagName      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt()
  groupGroupId Int
}

enum ExerciseType {
  running
  cycling
  swimming
}
